# QuizJex Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# Get these from Azure Portal → your Cognitive Services resource → Keys & Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: leave as * (allows all origins)
# Production: set to your deployed client URL e.g. https://quizjex.azurestaticapps.net
CLIENT_ORIGIN=*
